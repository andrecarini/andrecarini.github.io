# Local Claude Code state — planning docs and per-project settings
# are for local iteration and don't belong in the public repo.
.claude/
.claude-plans/

# Build output — generated in CI by .github/workflows/deploy.yml, never
# committed from a dev machine.
dist/

# Local secrets (GITHUB_TOKEN etc.) — never commit.
.env
.env.*
!.env.example

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
